# GitHub REST API Configuration
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPO=your_github_repository_name_here
GITHUB_OWNER=your_github_username_or_organization_here

# NextAuth.js Configuration
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Gmail SMTP Configuration
GMAIL_USER=your_gmail_email_here@gmail.com
GMAIL_APP_PASSWORD=your_gmail_16_character_app_password_here
